# REVIVE ML Environment Variables
# Copy this to .env and fill in your values

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openrouter | anthropic | bedrock | local
LLM_PROVIDER=openrouter

# OpenRouter (default demo path — no AWS approval needed)
OPENROUTER_API_KEY=sk-or-v1-....
OPENROUTER_MODEL=anthropic/claude-3-haiku
# claude-3-haiku supports vision via Anthropic's API directly
# claude-3-5-haiku is routed via Bedrock (no vision) — don't use for grading
# Other vision-capable options: anthropic/claude-3-5-sonnet, google/gemini-flash-1.5

# Anthropic direct (alternative)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# AWS Bedrock (production path — swap with one env var)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-haiku-20240307-v1:0

# ─── Redis (demand index + grade cache in production) ─────────────────────────
# Set USE_REDIS=false to skip Redis entirely (no timeout, works offline/demo)
# The system falls back to: demand_index.json → in-memory synthetic index
USE_REDIS=false

# Only needed if USE_REDIS=true (production)
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── AWS (for backend deploy — Track B) ───────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# ─── Django backend (Track B) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://revive:revive@localhost:5432/revive
SECRET_KEY=dev-secret-key-change-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
