# ══════════════════════════════════════════════════════════════════════════════
#  Root .env — OPTIONAL overrides for `docker compose`.  SAFE TO SHARE (no secrets).
#     (PowerShell)  Copy-Item .env.example .env
#
#  You usually DON'T need this: docker-compose already provides local Postgres,
#  Redis and MinIO. Only set these to turn ON optional AI features in the Docker
#  stack. docker-compose substitutes them into the services (blank = disabled).
# ══════════════════════════════════════════════════════════════════════════════

# LLM review panels + grading captions (free key at https://openrouter.ai)
LLM_PROVIDER=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Virtual Try-On — free HuggingFace token lifts the quota ~60s → ~1000s/day
# (https://huggingface.co/settings/tokens, Read scope)
HF_TOKEN=

# Try-On HuggingFace Space (leave blank for the default yisol/IDM-VTON)
TRYON_HF_SPACE=
