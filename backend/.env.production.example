# ══════════════════════════════════════════════════════════════════════════════
#  PRODUCTION environment TEMPLATE — placeholders only. NEVER commit real values.
#
#  On the host (e.g. the Render dashboard) set these as environment variables, or
#  copy to backend/.env ON THE SERVER and fill with REAL secrets. Do NOT put real
#  production keys in any file that is committed to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
# Generate a strong key:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=__REPLACE_WITH_A_STRONG_RANDOM_KEY__
DEBUG=False
ALLOWED_HOSTS=your-backend.onrender.com

# Cross-site frontend (Vercel) over HTTPS — required for cookies + CORS.
# With DEBUG=False the auth cookie automatically becomes SameSite=None + Secure.
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# ── Database — Supabase Postgres ──────────────────────────────────────────────
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres

# ── Redis — Upstash (use rediss:// for TLS). Django cache + Celery broker. ─────
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
# IMPORTANT: the tryon-service must use a SEPARATE Redis database/instance from
# Django, or the two Celery apps collide (tryon-worker steals Django's tasks).
# e.g. Django → …/0, tryon service+worker → …/1 (or a second Upstash instance).

# ── Object storage — AWS S3 (+ optional CloudFront CDN) ───────────────────────
# Do NOT set AWS_S3_ENDPOINT_URL in production — that is only for local MinIO.
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=ap-south-1
AWS_ACCESS_KEY_ID=__AWS_ACCESS_KEY_ID__
AWS_SECRET_ACCESS_KEY=__AWS_SECRET_ACCESS_KEY__
AWS_CLOUDFRONT_DOMAIN=

# ── AI / LLM ──────────────────────────────────────────────────────────────────
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=__OPENROUTER_API_KEY__
OPENROUTER_MODEL=anthropic/claude-3-haiku
HF_TOKEN=__HUGGINGFACE_TOKEN__

# Alternative LLM provider (AWS Bedrock) — swap by changing LLM_PROVIDER:
# LLM_PROVIDER=bedrock
# AWS_REGION=ap-south-1
# BEDROCK_MODEL_ID=anthropic.claude-haiku-20240307-v1:0
