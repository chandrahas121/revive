# ══════════════════════════════════════════════════════════════════════════════
#  LOCAL / DEV environment — SAFE TO SHARE. Contains NO real secrets.
#
#  Setup (run the backend NATIVELY):
#     (PowerShell)  Copy-Item backend/.env.example backend/.env
#
#  NOTE: If you run with Docker (`docker compose up`) you do NOT need this file —
#  docker-compose provides local Postgres, Redis and MinIO automatically. This
#  file is only for running the backend natively (python manage.py runserver).
#
#  For production values see  backend/.env.production.example
# ══════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=dev-insecure-key-not-for-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origins (Vite dev server) — needed for CORS + auth cookies
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite file — no Postgres needed for dev.
DATABASE_URL=sqlite:///dev.sqlite3

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave EMPTY for native dev: cache falls back to in-memory and the async
# grading / try-on paths run in a background thread (no Redis/Celery required).
REDIS_URL=

# ── Object storage ────────────────────────────────────────────────────────────
# Leave EMPTY for native dev: uploads use the local media/ folder.
# (Presigned uploads to MinIO/S3 are only exercised in the Docker stack.)
AWS_STORAGE_BUCKET_NAME=

# ── Optional AI features (leave blank to use offline heuristics) ───────────────
# Review panels + LLM grading captions. Free key at https://openrouter.ai
LLM_PROVIDER=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Virtual Try-On: a free HuggingFace token lifts the quota ~60s → ~1000s/day.
# Get one (Read scope) at https://huggingface.co/settings/tokens
HF_TOKEN=
