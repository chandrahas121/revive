# Copy this file to .env and fill in your values.
# Never commit .env to Git.

# ─── Django core ──────────────────────────────────────────────────────────────
SECRET_KEY=your-strong-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev — leave blank to use SQLite (db.sqlite3)
# DATABASE_URL=sqlite:///db.sqlite3

# Railway PostgreSQL (auto-set by Railway when you add a PostgreSQL service):
# DATABASE_URL=postgres://revive_user:password@your-rds-host.railway.app:5432/revive

# ─── AWS S3 (Image Storage) ───────────────────────────────────────────────────
# When set, ALL uploaded images go to S3 instead of the local media/ folder.
# Create a bucket + IAM user following amazon_submisstion/SERVICES_SETUP.md
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_STORAGE_BUCKET_NAME=revive-hackon-yourname
# AWS_S3_REGION_NAME=ap-south-1

# ─── Redis (Cache + Demand Index) ─────────────────────────────────────────────
# Upstash Redis (free, no credit card — get URL from upstash.com):
# REDIS_URL=rediss://default:password@your-url.upstash.io:6379

# Railway Redis (auto-set by Railway when you add a Redis service):
# REDIS_URL=redis://default:password@your-redis-host.railway.app:6379

# ─── CORS / CSRF ──────────────────────────────────────────────────────────────
# Local dev:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production (add your Vercel URL):
# CORS_ALLOWED_ORIGINS=https://revive.vercel.app
# CSRF_TRUSTED_ORIGINS=https://revive.vercel.app

# ─── ML / LLM (used by the ml/ module) ───────────────────────────────────────
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-3-haiku

# AWS Bedrock (production swap — one env var change):
# LLM_PROVIDER=bedrock
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-south-1
# BEDROCK_MODEL_ID=anthropic.claude-haiku-20240307-v1:0
