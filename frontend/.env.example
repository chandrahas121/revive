# Frontend environment — copy to  frontend/.env.local
#   (PowerShell)  Copy-Item frontend/.env.example frontend/.env.local
# Vite loads .env.local automatically and keeps it out of Git.

# Where the SPA sends API calls.

# LOCAL — Docker backend (backend1) on :8000:
VITE_API_URL=http://localhost:8000

# LOCAL — through the nginx gateway instead (tests per-service routing):
# VITE_API_URL=http://localhost

# PRODUCTION — your deployed backend:
# VITE_API_URL=https://your-backend.onrender.com
