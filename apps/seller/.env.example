# Copy this file to .env.local for local development.
# Vite automatically loads .env.local and keeps it out of Git.

# Backend API base URL (same Django backend as the consumer app)
VITE_API_URL=http://localhost:8000

# Consumer storefront URL — where "View on storefront" opens a relisted item.
VITE_STOREFRONT_URL=http://localhost:5173
